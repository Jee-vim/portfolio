---
import { BLOG } from "../lib/constants.ts"
const latestPost = BLOG[0];
const latestBlog = latestPost ? latestPost.data : null;
---
<a class="a-none" href={`/blog/${BLOG[0].slug}`} title={BLOG[0].data.title}>
  <p>{latestBlog.title}</p>
  <div>
  </div>
  <small>{latestBlog.date.toDateString().slice(4,10)}</small>
</a>

<style>
  a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  a p {
    width:100%;
    max-width: 300px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  a small {
    min-width: max-content;
    color: var(--foreground-muted)
  }
  @media (min-width: 768px) {
    a div {
      height: 1px;
      width: 100%;
      background: var(--foreground-muted)
    }
  }
</style>
